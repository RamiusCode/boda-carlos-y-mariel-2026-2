---
// Pase.astro
---

<section class="py-8 md:py-12 lg:py-16 px-4 relative overflow-hidden">
    <div
        class="absolute inset-0 bg-gradient-to-b from-[#f5f9f0]/40 via-[#faf8f5]/20 to-[#f5f9f0]/40 z-0"
    >
    </div>

    <div class="max-w-4xl mx-auto relative z-10">
        <div class="relative">
            <!-- CARD PASE -->
            <div
                class="bg-white/95 backdrop-blur-sm rounded-3xl border-2 border-[#CDA85A]/30 py-8 md:py-10 px-6 md:px-10 lg:px-12 shadow-sm max-w-xs mx-auto"
                id="card-pase"
            >
                <!-- ICONO TICKET -->
                <div
                    class="flex flex-col items-center justify-center mb-6"
                    id="icono-pase"
                >
                    <div
                        class="w-20 h-20 flex items-center justify-center mb-2"
                    >
                        <img
                            src="/imagenes/ticket.png"
                            alt="Ticket de pase"
                            class="w-full h-full object-contain icono-azul"
                        />
                    </div>
                </div>

                <!-- TÍTULO -->
                <div class="text-center mb-4" id="titulo-pase">
                    <h2
                        class="font-charm text-xl text-[#CDA85A] font-bold tracking-widest"
                    >
                        PASES ASIGNADOS
                    </h2>
                    <!-- Línea decorativa -->
                    <!-- <div class="flex items-center justify-center gap-3 mt-2">
                        <div
                            class="w-16 h-[2px] bg-gradient-to-r from-transparent to-[#CDA85A]"
                        >
                        </div>
                        <div class="w-2 h-2 rounded-full bg-[#CDA85A]"></div>
                        <div
                            class="w-16 h-[2px] bg-gradient-to-l from-transparent to-[#CDA85A]"
                        >
                        </div>
                    </div> -->
                </div>

                <!-- NÚMERO DE PASES -->
                <div class="text-center mb-2" id="numero-pase">
                    <span
                        class="font-charm text-5xl text-[#CDA85A] font-bold leading-none"
                        >2</span
                    >
                </div>

                <!-- ETIQUETA PASE -->
                <div class="text-center mb-6" id="etiqueta-pase">
                    <p
                        class="font-charm text-xl text-[#2E5FA3] tracking-widest"
                    >
                        PASES
                    </p>
                    <!-- Línea decorativa -->
                    <div class="flex items-center justify-center gap-3 mt-2">
                        <div
                            class="w-16 h-[2px] bg-gradient-to-r from-transparent to-[#CDA85A]"
                        >
                        </div>
                        <div class="w-2 h-2 rounded-full bg-[#CDA85A]"></div>
                        <div
                            class="w-16 h-[2px] bg-gradient-to-l from-transparent to-[#CDA85A]"
                        >
                        </div>
                    </div>
                </div>

                <!-- MENSAJE -->
                <div class="text-center mb-6" id="mensaje-pase">
                    <p
                        class="font-charm text-xl text-[#2E5FA3] leading-relaxed"
                    >
                        Esperamos contar con su presencia
                    </p>
                </div>

                <!-- ICONO PERSONA -->
              <div class="flex justify-center gap-2" id="persona-pase">
  <!-- Persona 1 -->
  <svg
    xmlns="http://www.w3.org/2000/svg"
    class="w-8 h-8 text-[#2E5FA3]"
    fill="currentColor"
    viewBox="0 0 24 24"
  >
    <path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/>
  </svg>

  <!-- Persona 2 -->
  <svg
    xmlns="http://www.w3.org/2000/svg"
    class="w-8 h-8 text-[#2E5FA3]"
    fill="currentColor"
    viewBox="0 0 24 24"
  >
    <path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/>
  </svg>
</div>

                <!-- DECORACIÓN INFERIOR -->
                <!-- <div class="flex justify-center mt-8" id="decoracion-pase">
                    <div class="flex gap-2">
                        <div
                            class="w-2 h-2 rounded-full bg-[#CDA85A] opacity-60"
                        >
                        </div>
                        <div
                            class="w-2 h-2 rounded-full bg-[#CDA85A] opacity-80"
                        >
                        </div>
                        <div class="w-2 h-2 rounded-full bg-[#CDA85A]"></div>
                        <div
                            class="w-2 h-2 rounded-full bg-[#CDA85A] opacity-80"
                        >
                        </div>
                        <div
                            class="w-2 h-2 rounded-full bg-[#CDA85A] opacity-60"
                        >
                        </div>
                    </div>
                </div> -->
            </div>
        </div>
    </div>
</section>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    if (typeof window !== "undefined") {
        document.addEventListener("DOMContentLoaded", () => {
            gsap.set("#card-pase", { opacity: 0, scale: 0.8 });
            gsap.set("#icono-pase", { opacity: 0, scale: 0.8 });
            gsap.set("#titulo-pase", { opacity: 0, scale: 0.8 });
            gsap.set("#numero-pase", { opacity: 0, scale: 0.8 });
            gsap.set("#etiqueta-pase", { opacity: 0, scale: 0.8 });
            gsap.set("#mensaje-pase", { opacity: 0, scale: 0.8 });
            gsap.set("#persona-pase", { opacity: 0, scale: 0.8 });
            gsap.set("#decoracion-pase", { opacity: 0, scale: 0.8 });

            ScrollTrigger.create({
                trigger: "#card-pase",
                start: "top 85%",
                end: "top 20%",
                onEnter: () => {
                    const tl = gsap.timeline();

                    tl.to("#card-pase", {
                        opacity: 1,
                        scale: 1,
                        duration: 1,
                        ease: "back.out(1.4)",
                    })
                        .to(
                            "#icono-pase",
                            {
                                opacity: 1,
                                scale: 1,
                                duration: 0.6,
                                ease: "back.out(1.5)",
                            },
                            "-=0.5",
                        )
                        .to(
                            "#titulo-pase",
                            {
                                opacity: 1,
                                scale: 1,
                                duration: 0.6,
                                ease: "back.out(1.4)",
                            },
                            "-=0.3",
                        )
                        .to(
                            "#numero-pase",
                            {
                                opacity: 1,
                                scale: 1,
                                duration: 0.7,
                                ease: "back.out(2)",
                            },
                            "-=0.3",
                        )
                        .to(
                            "#etiqueta-pase, #mensaje-pase, #persona-pase, #decoracion-pase",
                            {
                                opacity: 1,
                                scale: 1,
                                duration: 0.6,
                                ease: "back.out(1.3)",
                                stagger: 0.15,
                            },
                            "-=0.3",
                        );

                    // Flotación suave del icono
                    gsap.to("#icono-pase", {
                        y: -5,
                        duration: 2.5,
                        ease: "sine.inOut",
                        yoyo: true,
                        repeat: -1,
                        delay: 1.2,
                    });

                    // Pulso en puntos decorativos
                    gsap.to("#decoracion-pase > div > div", {
                        scale: 1.3,
                        opacity: 0.4,
                        duration: 2,
                        ease: "sine.inOut",
                        yoyo: true,
                        repeat: -1,
                        stagger: 0.15,
                        delay: 1.5,
                    });
                },
                onLeaveBack: () => {
                    gsap.set("#card-pase", { opacity: 0, scale: 0.8 });
                    gsap.set("#icono-pase", { opacity: 0, scale: 0.8 });
                    gsap.set("#titulo-pase", { opacity: 0, scale: 0.8 });
                    gsap.set("#numero-pase", { opacity: 0, scale: 0.8 });
                    gsap.set("#etiqueta-pase", { opacity: 0, scale: 0.8 });
                    gsap.set("#mensaje-pase", { opacity: 0, scale: 0.8 });
                    gsap.set("#persona-pase", { opacity: 0, scale: 0.8 });
                    gsap.set("#decoracion-pase", { opacity: 0, scale: 0.8 });
                },
            });
        });
    }
</script>

<style>
    #card-pase {
        transition: all 0.3s ease;
    }

    #card-pase:hover {
        box-shadow: 0 25px 60px rgba(205, 168, 90, 0.25);
        transform: translateY(-5px);
    }

    #icono-pase {
        will-change: transform;
    }

    .icono-azul {
        filter: brightness(0) saturate(100%) invert(18%) sepia(60%)
            saturate(800%) hue-rotate(200deg) brightness(85%) contrast(95%);
        transition:
            filter 0.3s ease,
            transform 0.3s ease;
    }

    #decoracion-pase > div > div {
        transition: all 0.3s ease;
    }

    #mensaje-pase p {
        transition: color 0.3s ease;
    }
</style>
